{
  "files": {
    "includes": [
      "**",
      "!**/recipes/*.yaml", // Conda recipes
      "!**/charts/**/templates/*.yaml" // Helm chart templates
      // "!**/*.svg" // SVGs
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "indentStyle": "space", // default is `tab`
    "lineWidth": 100
  },
  "linter": {
    "rules": {
      "a11y": {
        "noNoninteractiveElementInteractions": "warning"
      },
      "complexity": {
        "useSimplifiedLogicExpression": "warning",
        "useWhile": "warning"
      },
      "correctness": {
        "noGlobalDirnameFilename": "warning"
      },
      "suspicious": {
        "noConstantBinaryExpressions": "warning",
        "noDeprecatedImports": "warning",
        "noEmptyBlockStatements": "warning",
        "noEvolvingTypes": "warning",
        "noImportCycles": "warning",
        "noMisplacedAssertion": "warning"
      },
      "style": {
        "noValueAtRule": "error",
        "useGraphqlNamingConvention": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "lineWidth": 80,
      "operatorLinebreak": "before"
    },
    "experimentalEmbeddedSnippetsEnabled": true
  },
  "html": {
    //"experimentalFullSupportEnabled": true,
    "formatter": {
      //"enabled": true,
      "lineWidth": 80,
      "selfCloseVoidElements": "always"
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  }
}
